@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Plateforme Bibliothèque</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bibliotheque.Web.styles.css" asp-append-version="true" />

    <style>
        body.library-bg {
            background: url('/images/library-bg.png') no-repeat center center fixed;
            background-size: cover;
        }

       .page-overlay {
    min-height: 100vh;
   
    backdrop-filter: blur(3px);
}
    </style>
</head>


<body class="library-bg">
@{
    var jwt = Context.Session.GetString("jwt");
    var role = Context.Session.GetString("role");
    var userId = Context.Session.GetInt32("userId");
}

    <div class="page-overlay">
        <header>
           <nav class="navbar navbar-expand-lg navbar-dark shadow-sm mb-3 main-navbar">
                <div class="container">

                    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-page="/Index">
                        <img src="~/images/logo.png"
                             alt="Logo"
                             style="height:36px;width:auto;border-radius:6px;background:white;padding:2px;" />
                        <span>Bibliothèque ENSTICP</span>
                    </a>

                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#topNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="topNav">

                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-semibold">

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index">Accueil</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Livres">Livres</a>
                            </li>

                            @if (!string.IsNullOrEmpty(jwt))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Demandes">Mes demandes</a>
                                </li>
                            }

                            @if (role == "BIBLIOTHECAIRE" || role == "ADMIN")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Inscriptions">Inscriptions</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Users">Utilisateurs</a>

                                </li>
                                <li class="nav-item">
    <a class="nav-link" asp-page="/Attestation">Quitus</a>
</li>
                            }
                            <li class="nav-item">
    <a class="nav-link position-relative" asp-page="/Notifications">
        🔔 Notifications
        <span id="notifBadge"
              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
              style="display:none;">
            0
        </span>
    </a>
</li>

                            @if (role == "BIBLIOTHECAIRE")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Retours">Retours</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Privacy">À propos</a>
                            </li>

                        </ul>

                        <div class="d-flex align-items-center gap-2">

                            @if (string.IsNullOrEmpty(jwt))
                            {
                                <a class="btn btn-light btn-sm fw-bold" asp-page="/Login">
                                    Se connecter
                                </a>

                                <a class="btn btn-outline-light btn-sm fw-bold" asp-page="/Register">
                                    Créer un compte
                                </a>
                            }
                            else
                            {
                                <span class="text-white small me-2">
                                    Connecté
                                </span>

                                <a class="btn btn-outline-light btn-sm fw-bold" asp-page="/Logout">
                                    Logout
                                </a>
                            }

                        </div>

                    </div>
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-4">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted mt-4">
            <div class="container py-3 text-center">
                &copy; 2026 - Plateforme Bibliothèque ENSTICP
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
<script>
    async function loadNotificationCount() {
        const userId = '@userId';

        if (!userId) return;

        try {
            const res = await fetch(`/api/notifications/count/${userId}`);
            const data = await res.json();

            const badge = document.getElementById("notifBadge");

            if (data.count > 0) {
                badge.innerText = data.count;
                badge.style.display = "inline-block";
            } else {
                badge.style.display = "none";
            }
        } catch (e) {
            console.error("Erreur notif:", e);
        }
    }

    loadNotificationCount();
</script>
</body>
</html>