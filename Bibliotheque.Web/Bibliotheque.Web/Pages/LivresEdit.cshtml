@page "{id:int}"
@model Bibliotheque.Web.Pages.LivresEditModel
@{
    ViewData["Title"] = "Modifier un livre";
}

<div class="card p-4">
    <h3 class="mb-3">Modifier un livre</h3>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }

    <form method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Titre</label>
            <input asp-for="Titre" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Auteur</label>
            <input asp-for="Auteur" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Thème</label>
            <input asp-for="Theme" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Année</label>
            <input asp-for="AnneePublication" class="form-control" type="number" />
        </div>

        <button type="submit" class="btn btn-warning">Enregistrer</button>
        <a asp-page="/Livres" class="btn btn-secondary">Retour</a>
    </form>
</div>