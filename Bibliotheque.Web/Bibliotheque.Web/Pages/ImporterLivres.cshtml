@page
@model Bibliotheque.Web.Pages.ImporterLivresModel
@{
    ViewData["Title"] = "Importer Livres";
}

<div class="card p-4">
    <h2 class="mb-3">📥 Importer des livres (Excel)</h2>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }

    <form method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label class="form-label">Fichier Excel (.xlsx)</label>
            <input class="form-control" type="file" name="ExcelFile" accept=".xlsx" />
        </div>
        <button class="btn btn-primary" type="submit">Importer</button>
        <a class="btn btn-outline-secondary" asp-page="/Livres">Retour</a>
    </form>

    @if (Model.Errors?.Any() == true)
    {
        <hr />
        <h5>Erreurs</h5>
        <ul>
            @foreach (var e in Model.Errors)
            {
                <li>Ligne @e.Row : @e.Error</li>
            }
        </ul>
    }
</div>