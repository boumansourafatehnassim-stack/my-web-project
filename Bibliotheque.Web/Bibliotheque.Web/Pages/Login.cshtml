@page
@model Bibliotheque.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="page-shell">
    <div class="auth-card">
        <div class="auth-head">
            <h2 class="auth-title">Plateforme Bibliothèque</h2>
            <p class="auth-sub">Connectez-vous pour gérer les livres, demandes et emprunts.</p>
        </div>

        <div class="auth-body">
            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger">@Model.Error</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" asp-for="Email" placeholder="ex: bib@ensptic.dz" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mot de passe</label>
                    <input class="form-control" asp-for="MotDePasse" type="password" placeholder="••••••••" />
                </div>

                <button class="btn btn-primary w-100" type="submit">Se connecter</button>
                <div class="text-center mt-3">
                    <a asp-page="/Register" class="btn btn-outline-primary w-100">
                        Créer un compte
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
