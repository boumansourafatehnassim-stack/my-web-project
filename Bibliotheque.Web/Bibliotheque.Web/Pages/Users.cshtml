@page
@model Bibliotheque.Web.Pages.UsersModel
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<div class="page-section">
    <div class="dashboard-hero">
        <h2 class="mb-1">Gestion des utilisateurs</h2>
        <p class="mb-0 text-white">Rechercher, activer, désactiver et réinitialiser les comptes.</p>
    </div>
</div>

<div class="content-panel page-section">
    <form method="get" class="row g-2">
        <div class="col-md-6">
            <input type="text"
                   name="Search"
                   value="@Model.Search"
                   class="form-control"
                   placeholder="Rechercher par matricule ou email" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">
                Rechercher
            </button>
        </div>
        <div class="col-auto">
            <a asp-page="/Users" class="btn btn-outline-secondary">
                Réinitialiser
            </a>
        </div>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<div class="table-wrap page-section">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Photo</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Matricule</th>
                    <th>Rôle</th>
                    <th>État</th>
                    <th>Date création</th>
                    <th style="min-width:260px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.PhotoPath))
                            {
                                <img src="@u.PhotoPath" class="user-thumb" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@u.Nom</td>
                        <td>@u.Prenom</td>
                        <td>@u.Email</td>
                        <td>@u.Matricule</td>
                        <td>@u.Role</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactif</span>
                            }
                        </td>
                        <td>@u.DateCreation.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div class="d-flex flex-column gap-2">

                                <!-- زر عرض البطاقة -->
                                <a asp-page="/CarteEtudiant"
                                   asp-route-id="@u.Id"
                                   class="btn btn-info btn-sm w-100">
                                    Voir la carte
                                </a>

                                <!-- تفعيل/تعطيل -->
                                <form method="post" asp-page-handler="ToggleActive">
                                    <input type="hidden" name="UserId" value="@u.Id" />
                                    <input type="hidden" name="Search" value="@Model.Search" />

                                    @if (u.IsActive)
                                    {
                                        <button type="submit" class="btn btn-warning btn-sm w-100">
                                            Désactiver le compte
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-success btn-sm w-100">
                                            Activer le compte
                                        </button>
                                    }
                                </form>

                                <!-- تغيير كلمة السر -->
                                <form method="post" asp-page-handler="ResetPassword" class="d-flex gap-2">
                                    <input type="hidden" name="UserId" value="@u.Id" />
                                    <input type="hidden" name="Search" value="@Model.Search" />

                                    <input type="text"
                                           name="NewPassword"
                                           class="form-control form-control-sm"
                                           placeholder="Nouveau mot de passe"
                                           required />

                                    <button type="submit" class="btn btn-primary btn-sm">
                                        Modifier
                                    </button>
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>