@page
@model Bibliotheque.Api.Pages.LivresModel
@{
    ViewData["Title"] = "Livres";

    var jwt = HttpContext.Session.GetString("jwt");
    var role = HttpContext.Session.GetString("role");
    var userId = HttpContext.Session.GetInt32("userId");

    var isAuthenticated = !string.IsNullOrEmpty(jwt);
    var isBibliothecaire = role == "BIBLIOTHECAIRE";
    var isAdmin = role == "ADMIN";
    var canManage = isBibliothecaire || isAdmin;
}

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-5">
        <label class="form-label">Recherche</label>
        <input class="form-control" asp-for="Search" placeholder="Titre ou auteur..." />
    </div>

    <div class="col-md-3">
        <label class="form-label">Thème</label>
        <input class="form-control" asp-for="Theme" placeholder="Ex: Informatique" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Page size</label>
        <select class="form-select" asp-for="PageSize">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>

    <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary w-100">Filtrer</button>
        <a asp-page="/Livres" class="btn btn-outline-secondary w-100">Reset</a>
    </div>
</form>

<div class="card p-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">📚 Liste des Livres</h2>
            <div class="text-muted">Catalogue de la bibliothèque</div>
        </div>

        <div class="d-flex align-items-center gap-2">
            @if (canManage)
            {
                <a class="btn btn-success btn-sm" asp-page="/AjouterLivre">+ Ajouter un livre</a>
               <a class="btn btn-outline-success btn-sm" asp-page="/LivresImport">Importer Excel</a>
            }

            <span class="badge-soft">@(Model.LivresPaged?.TotalCount ?? 0) livres</span>
        </div>
    </div>

    <div class="alert alert-info">
        JWT: @(isAuthenticated ? "OK" : "NULL") |
        userId: @(userId?.ToString() ?? "NULL") |
        role: @(role ?? "NULL")
    </div>

    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Adresse Bibliogr.</th>
                    <th>Année</th>
                    <th>Langue</th>
                    <th>Thème</th>
                    <th>Exemplaires</th>
                    <th>Disponibles</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.LivresPaged?.Items != null && Model.LivresPaged.Items.Any())
                {
                    @foreach (var l in Model.LivresPaged.Items)
                    {
                        <tr>
                            <td>@l.Id</td>
                            <td>@l.Titre</td>
                            <td>@l.Auteur</td>
                            <td>@(string.IsNullOrWhiteSpace(l.AdresseBibliogr) ? "-" : l.AdresseBibliogr)</td>
                            <td>@l.AnneePublication</td>
                            <td>@(string.IsNullOrWhiteSpace(l.Langue) ? "-" : l.Langue)</td>
                            <td>@(string.IsNullOrWhiteSpace(l.Theme) ? "-" : l.Theme)</td>
                            <td>@l.NombreExemplaires</td>
                            <td>
                                @if (l.NombreDisponibles > 0)
                                {
                                    <span class="badge bg-success">@l.NombreDisponibles</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                            </td>
                            <td>
                                @if (!isAuthenticated)
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-page="/Login">Se connecter</a>
                                }
                                else if (canManage)
                                {
                                    <a class="btn btn-sm btn-warning me-1" asp-page="/ModifierLivre" asp-route-id="@l.Id">Edit</a>

                                    <form method="post"
                                          asp-page-handler="Delete"
                                          asp-route-id="@l.Id"
                                          class="d-inline"
                                          onsubmit="return confirm('Confirmer la suppression de ce livre ?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-primary"
                                       asp-page="/Demander"
                                       asp-route-livreId="@l.Id">
                                        Demander
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">
                            Aucun livre trouvé.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

   @if (Model.LivresPaged != null && Model.LivresPaged.TotalPages > 1)
{
    var currentPage = Model.LivresPaged.Page;
    var totalPages = Model.LivresPaged.TotalPages;

    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, currentPage + 2);

    <nav class="mt-4">
        <ul class="pagination justify-content-center flex-wrap">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-page="/Livres"
                   asp-route-Search="@Model.Search"
                   asp-route-Theme="@Model.Theme"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-PageNumber="@(currentPage - 1)">
                    Précédent
                </a>
            </li>

            @if (startPage > 1)
            {
                <li class="page-item @(currentPage == 1 ? "active" : "")">
                    <a class="page-link"
                       asp-page="/Livres"
                       asp-route-Search="@Model.Search"
                       asp-route-Theme="@Model.Theme"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-PageNumber="1">
                        1
                    </a>
                </li>

                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-page="/Livres"
                       asp-route-Search="@Model.Search"
                       asp-route-Theme="@Model.Theme"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-PageNumber="@i">
                        @i
                    </a>
                </li>
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "active" : "")">
                    <a class="page-link"
                       asp-page="/Livres"
                       asp-route-Search="@Model.Search"
                       asp-route-Theme="@Model.Theme"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-PageNumber="@totalPages">
                        @totalPages
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-page="/Livres"
                   asp-route-Search="@Model.Search"
                   asp-route-Theme="@Model.Theme"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-PageNumber="@(currentPage + 1)">
                    Suivant
                </a>
            </li>

        </ul>
    </nav>
}
  
</div>